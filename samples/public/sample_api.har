            "text": "{\"data\":[{\"issue_id\":\"ISS-101\",\"project_id\":\"PRJ-001\",\"title\":\"Memory leak in long-running decryption sessions\",\"body\":\"After ~6 hours of continuous operation, memory usage climbs to 4GB+.\\n\\nSteps to reproduce:\\n1. Start decoder with large corpus\\n2. Let run overnight\\n3. Observe RSS growth\",\"status\":\"open\",\"priority\":\"high\",\"type\":\"bug\",\"created_at\":\"2025-12-01T09:00:00Z\",\"updated_at\":\"2026-01-08T14:00:00Z\",\"closed_at\":null,\"due_date\":\"2026-02-01\",\"estimated_hours\":16.0,\"actual_hours\":null,\"author\":{\"id\":1002,\"username\":\"grhopper\",\"avatar_url\":\"https://i.pravatar.cc/150?u=grhopper\"},\"assignees\":[{\"id\":1001,\"username\":\"aturing\",\"avatar_url\":\"https://i.pravatar.cc/150?u=aturing\"}],\"labels\":[{\"id\":\"L-1\",\"name\":\"bug\",\"color\":\"#e74c3c\"},{\"id\":\"L-5\",\"name\":\"performance\",\"color\":\"#f39c12\"}],\"milestone\":{\"id\":\"M-3\",\"title\":\"v2.0 Release\",\"due_date\":\"2026-03-01\",\"progress\":0.65},\"comments_count\":12,\"reactions\":{\"thumbs_up\":5,\"thumbs_down\":0,\"heart\":2,\"eyes\":3}},{\"issue_id\":\"ISS-107\",\"project_id\":\"PRJ-001\",\"title\":\"Support for Naval Enigma M4 variant\",\"body\":\"The current implementation only handles 3-rotor Enigma. We need support for the 4-rotor Naval variant (M4) used by U-boats.\",\"status\":\"open\",\"priority\":\"high\",\"type\":\"feature\",\"created_at\":\"2026-01-05T11:30:00Z\",\"updated_at\":\"2026-01-12T09:00:00Z\",\"closed_at\":null,\"due_date\":\"2026-04-15\",\"estimated_hours\":40.0,\"actual_hours\":null,\"author\":{\"id\":1001,\"username\":\"aturing\",\"avatar_url\":\"https://i.pravatar.cc/150?u=aturing\"},\"assignees\":[{\"id\":1001,\"username\":\"aturing\",\"avatar_url\":\"https://i.pravatar.cc/150?u=aturing\"},{\"id\":1002,\"username\":\"grhopper\",\"avatar_url\":\"https://i.pravatar.cc/150?u=grhopper\"}],\"labels\":[{\"id\":\"L-2\",\"name\":\"enhancement\",\"color\":\"#3498db\"},{\"id\":\"L-3\"